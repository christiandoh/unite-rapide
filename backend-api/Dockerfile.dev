FROM node:20-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends wget curl && rm -rf /var/lib/apt/lists/*
RUN npm install -g nodemon prisma
COPY package.json package-lock.json* ./
RUN npm ci
COPY . .
EXPOSE 3000
CMD ["nodemon", "--watch", "src", "--ext", "js,json", "--exec", "node src/server.js"]
